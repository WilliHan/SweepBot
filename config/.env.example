# SweepBot 환경변수 예시
# 실제 운영 시 .env 파일에 아래 값을 채워 넣는다.

# ── AI 제공자 API 키 ───────────────────────────────────────────────
GEMINI_API_KEY=              # Google Gemini API 키 (기본 AI 모델)
OPENAI_API_KEY=              # OpenAI API 키 (선택)
OPENROUTER_API_KEY=          # OpenRouter API 키 (선택)
DEEPSEEK_API_KEY=            # DeepSeek API 키 (선택)

# ── MSS 연동 ──────────────────────────────────────────────────────
MSS_API_BASE_URL=https://mlt-service.n-e.kr/api
MSS_APP_BASE_URL=https://mlt-service.n-e.kr/mss
MSS_SECURE_COOKIES=true
MSS_COOKIE_DOMAIN=

# ── 데이터 소스 ───────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPA_MSS_TOKEN=

KRX_ID=
KRX_PW=
KRX_WEB_ID=
KRX_WEB_PASSWORD=
KRX_WEB_LOGIN_ENABLED=false

# ── 외부 API ─────────────────────────────────────────────────────
DART_API_KEY=                # DART 전자공시 API
ECOS_API_KEY=                # 한국은행 ECOS API
DATA_GO_KR_SERVICE_KEY=      # 공공데이터 포털
NAVER_CLIENT_ID=             # 네이버 검색 API
NAVER_CLIENT_SECRET=

# ── 이메일/알림 ───────────────────────────────────────────────────
GOOGLE_EMAIL_USER=
GOOGLE_EMAIL_PW=
RESEND_API_KEY=
RESEND_EMAIL_USER=
RESEND_EMAIL_PW=

# ── 증권사 연동 ───────────────────────────────────────────────────
KIWOOM_BASE_URL=
KIWOOM_APPKEY=
KIWOOM_SECRETKEY=

# ── 기타 ─────────────────────────────────────────────────────────
THEME_MASTER_AUTO_UPDATE=false
